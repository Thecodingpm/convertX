{
    "compilerOptions": {
        "lib": [
            "dom",
            "ES2017"
        ],
        "jsx": "react",
        "target": "ES6",
        "module": "ES6",
        "moduleResolution": "bundler",
        "allowSyntheticDefaultImports": true,
        "esModuleInterop": true,
        "strict": true,
        "skipLibCheck": true
    }
}